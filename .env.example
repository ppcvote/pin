# Pin runtime — required
TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=
NODE_ENV=development

# HTTP server (webhook receiver + image endpoint) — default 3000
PIN_HTTP_PORT=3000
# Public URL Pin advertises for image deliveries (LINE needs HTTPS URL,
# not raw bytes — Pin saves PNGs and serves them via /image/<file>)
PIN_PUBLIC_URL=https://YOUR_TUNNEL.trycloudflare.com

# Optional LLM brain — used as fallback router for freeform text (legacy mode),
# and as the Agent Mode router below.
# Default is "openrouter" (free-first model chain, same key the OpenClaw fleet uses).
BRAIN_MODE=openrouter      # "openrouter" | "gemini" | "ollama"

# OpenRouter (default) — 3-model fallback chain
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_FALLBACK=google/gemini-2.5-flash,anthropic/claude-haiku-4.5

# Gemini direct (legacy)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama local (legacy)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:7b

# Agent Mode (PIN_AGENT_MODE.md) — opt-in. When on, freeform text routes
# through the LLM tool-picker with @ppcvote/prompt-shield injection gate +
# forced preview on POST/PUT/DELETE.
PIN_AGENT_MODE=false

# ATR skill threat scan (agent-threat-rules) — on by default. Every SKILL.md
# is scanned at load; a critical-severity match refuses the skill. Set to
# false only for local debugging of a skill the scanner rejects.
PIN_ATR_SCAN=true

# LINE Messaging API
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# === Skill secrets (per skill — each skills/*/SKILL.md lists what it needs) ===

# MindThread (https://mindthread.tw) — 6 actions, no webhooks declared
MT_API_KEY=
MT_BASE_URL=https://mindthread.tw

# UD House (https://social.8338.hk) — 7 actions, 2 webhooks (lead.created,
# listing.status_changed)
UDH_API_KEY=
UDH_BASE_URL=https://social.8338.hk
UDH_WEBHOOK_SECRET=

# UltraGrowth (managed-service flywheel; PIN_FLYWHEEL.md §1) — 4 actions,
# 2 webhooks (report.ready, lead.created)
UG_API_KEY=ug_mock_test_key             # change for prod
UG_BASE_URL=http://localhost:4001       # mock dev; flip to UltraLab live host
UG_WEBHOOK_SECRET=ug_mock_webhook_secret
# Shared secret for Pin → UltraLab flywheel events
# (header X-Pin-Shared-Secret on POST /api/flywheel-event)
UG_FLYWHEEL_SECRET=

# Slides generator service (skills/slides)
SLIDES_BASE_URL=http://127.0.0.1:3210
SLIDES_API_KEY=change-me

# Domain service (skills/domain — GENESIS P0). `npm run domain` to start.
DOMAIN_BASE_URL=http://127.0.0.1:3211
DOMAIN_API_KEY=change-me
# Upstream provider behind the swappable DomainProvider contract:
#   cloudflare — real registrar (needs the two CLOUDFLARE_* creds below)
#   mock       — deterministic sandbox, no network, for dogfood/demo
DOMAIN_PROVIDER=mock
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Real charging stays OFF until an operator flips this to 1 — until then
# /register simulates (sandbox dry-run) even after the human confirm key.
DOMAIN_ALLOW_REAL_REGISTRATION=0
# Optional: TLD set for 比價 + per-day register cap
#DOMAIN_QUOTE_TLDS=com,net,org,io,dev,app,ai
#DOMAIN_REGISTER_DAILY_CAP=5

# WhatsApp Business Platform (Meta Cloud API) — PIN_WHATSAPP.md
# Leave blank to skip the WhatsApp channel at startup.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# App secret for webhook signature verification (X-Hub-Signature-256) — Phase 3
WHATSAPP_APP_SECRET=
