# Pin runtime — required
TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=
NODE_ENV=development

# HTTP server (webhook receiver) — default 3000
PIN_HTTP_PORT=3000

# Optional LLM brain (used as fallback router for freeform text)
BRAIN_MODE=gemini          # "gemini" | "ollama"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:7b

# === Skill secrets (per skill — see each skills/*/SKILL.md `secrets:` list) ===

# MindThread (https://mindthread.tw)
MT_API_KEY=
MT_BASE_URL=https://mindthread.tw

# UD House (https://social.8338.hk)
UDH_API_KEY=
UDH_BASE_URL=https://social.8338.hk
UDH_WEBHOOK_SECRET=         # for inbound webhook HMAC signature verification
